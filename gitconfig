[user]
	name = Matt MacAulay
	email = matt@m6y.ca
[color]
  diff = auto
  status = auto
  branch = auto
[core]
	excludesfile = ~/.gitignore
  editor = vim
  autocrlf = input
[apply]
  whitespace = nowarn
[format]
  pretty = %C(yellow)%h%Creset %s %C(red)(%cr)%Creset
[credential]
	helper = osxkeychain
[push]
  default = simple
